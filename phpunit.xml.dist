<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache">
  <testsuites>
    <testsuite name="RunAPI package">
      <directory>tests</directory>
      <exclude>tests/Unit/AllResourcesOfflineSmokeTest.php</exclude>
    </testsuite>
  </testsuites>
</phpunit>
